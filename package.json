{
  "name": "shopify-insights-mcp",
  "version": "1.0.0",
  "description": "MCP Server for Shopify that delivers actionable business insights — sales comparisons, inventory alerts, customer segmentation, and operational metrics with automated recommendations.",
  "main": "dist/index.js",
  "bin": {
    "shopify-insights-mcp": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "setup": "node dist/cli/index.js init",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "shopify",
    "analytics",
    "insights",
    "business-intelligence",
    "ecommerce",
    "model-context-protocol",
    "claude",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/VenticinqueMauro/shopify-insights-mcp.git"
  },
  "homepage": "https://github.com/VenticinqueMauro/shopify-insights-mcp#readme",
  "bugs": {
    "url": "https://github.com/VenticinqueMauro/shopify-insights-mcp/issues"
  },
  "author": "Mauro Venticinque",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0",
    "node-fetch": "^3.3.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  }
}
