# Required
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_access_token_here

# Optional — override timezone for today/yesterday date boundaries
# Uses IANA timezone names. Auto-detected from your Shopify store if not set.
# SHOPIFY_TIMEZONE=America/New_York

# Optional — Shopify Admin API version (default: 2025-01)
# SHOPIFY_API_VERSION=2025-01

# Optional — max records per tool call (default: 1000)
# SHOPIFY_MAX_RECORDS=1000
